NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchestra
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/orchestra

REDIS_URL=redis://localhost:6379
QUEUE_MODE=inline
QUEUE_PREFIX=orchestra

STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
SIGNED_URL_TTL_SECONDS=3600
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PASSWORD_HASH_COST=12

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_REASONING=claude-3-7-sonnet-latest
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/v1/oauth/slack/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/oauth/google/callback
GOOGLE_PUBSUB_TOPIC=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/v1/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common

WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_READINESS_MODE=disabled

CONNECTOR_CREDENTIAL_VAULT_MODE=encrypted_file
CONNECTOR_OAUTH_STATE_SECRET=change_me_connector_state_secret
CONNECTOR_SYNC_BATCH_SIZE=100
CONNECTOR_SYNC_MAX_BACKFILL_DAYS=30

RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.2
RETRIEVAL_USE_HYBRID=true
RETRIEVAL_DOC_WEIGHT=1.0
RETRIEVAL_COMM_WEIGHT=0.8
RETRIEVAL_ACCEPTED_TRUTH_BOOST=1.2
METRICS_TOKEN=
