model MessageInsight {
  id                   String                 @id @default(uuid()) @db.Uuid
  projectId            String                 @map("project_id") @db.Uuid
  connectorId          String                 @map("connector_id") @db.Uuid
  provider             CommunicationProvider
  messageId            String                 @map("message_id") @db.Uuid
  threadId             String                 @map("thread_id") @db.Uuid
  bodyHash             String                 @map("body_hash")
  insightType          MessageInsightType     @map("insight_type")
  status               MessageInsightStatus   @default(detected)
  summary              String
  confidence           Decimal                @db.Decimal(4, 3)
  shouldCreateProposal Boolean                @default(false) @map("should_create_proposal")
  shouldCreateDecision Boolean                @default(false) @map("should_create_decision")
  proposalType         ProposalType?          @map("proposal_type")
  affectedRefsJson     Json?                  @map("affected_refs_json")
  evidenceJson         Json?                  @map("evidence_json")
  oldUnderstandingJson Json?                  @map("old_understanding_json")
  newUnderstandingJson Json?                  @map("new_understanding_json")
  decisionStatement    String?                @map("decision_statement")
  impactSummaryJson    Json?                  @map("impact_summary_json")
  uncertaintyJson      Json?                  @map("uncertainty_json")
  modelJson            Json?                  @map("model_json")
  generatedProposalId  String?                @map("generated_proposal_id") @db.Uuid
  generatedDecisionId  String?                @map("generated_decision_id") @db.Uuid
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  project              Project                @relation(fields: [projectId], references: [id])
  connector            CommunicationConnector @relation(fields: [connectorId], references: [id])
  message              CommunicationMessage   @relation(fields: [messageId], references: [id])
  thread               CommunicationThread    @relation(fields: [threadId], references: [id])
  generatedProposal    SpecChangeProposal?    @relation("generated_message_insights", fields: [generatedProposalId], references: [id])
  generatedDecision    DecisionRecord?        @relation("generated_message_insights", fields: [generatedDecisionId], references: [id])

  @@unique([messageId, bodyHash])
  @@index([projectId, insightType, status])
  @@index([projectId, status, createdAt(sort: Desc)])
  @@index([threadId, createdAt(sort: Desc)])
  @@map("message_insights")
}

model ThreadInsight {
