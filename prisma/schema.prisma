  providerAttachmentId String?             @map("provider_attachment_id")
  filename          String?
  mimeType          String?                @map("mime_type")
  fileSize          BigInt?                @map("file_size")
  providerUrl       String?                @map("provider_url")
  storageStatus     AttachmentStorageStatus @default(metadata_only) @map("storage_status")
  fileKey           String?                @map("file_key")
  extractionText    String?                @map("extraction_text")
  rawMetadataJson   Json?                  @map("raw_metadata_json")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  message           CommunicationMessage   @relation(fields: [messageId], references: [id])
  project           Project                @relation(fields: [projectId], references: [id])
  connector         CommunicationConnector @relation(fields: [connectorId], references: [id])

  @@unique([messageId, providerAttachmentId])
  @@index([projectId, provider, createdAt(sort: Desc)])
  @@index([messageId])
  @@map("communication_attachments")
}

model CommunicationMessageChunk {
  id                String                  @id @default(uuid()) @db.Uuid
  messageId         String                  @map("message_id") @db.Uuid
  threadId          String                  @map("thread_id") @db.Uuid
  projectId         String                  @map("project_id") @db.Uuid
  connectorId       String                  @map("connector_id") @db.Uuid
  provider          CommunicationProvider
  chunkIndex        Int                     @map("chunk_index")
  content           String
  contextualContent String?                 @map("contextual_content")
  lexicalContent    String                  @map("lexical_content")
  embedding         Unsupported("vector(1536)")?
  tokenCount        Int                     @map("token_count")
  metadataJson      Json?                   @map("metadata_json")
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  message           CommunicationMessage    @relation(fields: [messageId], references: [id])
  thread            CommunicationThread     @relation(fields: [threadId], references: [id])
  project           Project                 @relation(fields: [projectId], references: [id])
  connector         CommunicationConnector  @relation(fields: [connectorId], references: [id])

  @@unique([messageId, chunkIndex])
  @@index([projectId, provider, threadId])
  @@index([messageId])
  @@map("communication_message_chunks")
}

model CommunicationConnector {
  id                String                       @id @default(uuid()) @db.Uuid
  projectId         String                       @map("project_id") @db.Uuid
  provider          CommunicationProvider
  accountLabel      String                       @map("account_label")
  status            CommunicationConnectorStatus
  credentialsRef    String?                      @map("credentials_ref")
  configJson        Json?                        @map("config_json")
  providerCursorJson Json?                       @map("provider_cursor_json")
  lastSyncedAt      DateTime?                    @map("last_synced_at") @db.Timestamptz(6)
  lastError         String?                      @map("last_error")
  createdBy         String                       @map("created_by") @db.Uuid
  createdAt         DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  project           Project                      @relation(fields: [projectId], references: [id])
  creator           User                         @relation("created_connectors", fields: [createdBy], references: [id])
  syncRuns          CommunicationSyncRun[]
  threads           CommunicationThread[]
  messages          CommunicationMessage[]
  messageRevisions  CommunicationMessageRevision[]
  attachments       CommunicationAttachment[]
  messageChunks     CommunicationMessageChunk[]
  webhookEvents     ProviderWebhookEvent[]
  messageInsights   MessageInsight[]
  threadInsights    ThreadInsight[]

  @@unique([projectId, provider])
  @@index([projectId, status])
  @@map("communication_connectors")
}

model CommunicationSyncRun {
