{
  "name": "orchestra-product-brain-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "eval:socrates": "tsx scripts/run-socrates-evals.ts",
    "eval:messages": "tsx scripts/run-message-intelligence-evals.ts",
    "eval:all": "tsx scripts/run-all-evals.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@aws-sdk/s3-request-presigner": "^3.782.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.50.2",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "mime-types": "^2.1.35",
    "openai": "^4.68.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "slugify": "^1.6.6",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.5",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.1.1"
  }
}
